import os
from dotenv import load_dotenv
from groq import Groq

# 1. Cette ligne cherche le fichier .env et charge les variables
load_dotenv()

# 2. On récupère la valeur de GROQ_API_KEY stockée dans le fichier
api_key = os.getenv("GROQ_API_KEY=votre_cle_ici")

# 3. On initialise le client Groq avec cette clé
client = Groq(api_key=api_key)

